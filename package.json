{
  "name": "@muxiu1997/vue-easy-di",
  "type": "module",
  "version": "0.1.0-rc.2",
  "description": "A Vue composable library for simplifying dependency injection.",
  "source": "src/index.ts",
  "author": "MuXiu1997 <muxiu1997@gmail.com> (https://github.com/MuXiu1997/)",
  "license": "MIT",
  "homepage": "https://github.com/MuXiu1997/vue-easy-di",
  "repository": "MuXiu1997/vue-easy-di",
  "keywords": [
    "vue",
    "vue-demi",
    "DI",
    "dependency injection",
    "provider",
    "inject"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "script": "./dist/index.iife.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "unpkg": "dist/index.iife.js",
  "jsdelivr": "dist/index.iife.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint --fix .",
    "test": "vitest --typecheck",
    "coverage": "vitest --typecheck --coverage",
    "build": "tsdown"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24"
  },
  "peerDependencies": {
    "@vue/composition-api": "^1.0.0-rc.1",
    "vue": "^2.0.0 || >=3.0.0"
  },
  "peerDependenciesMeta": {
    "@vue/composition-api": {
      "optional": true
    }
  },
  "dependencies": {
    "vue-demi": "latest"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.1.0",
    "@types/node": ">=24",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "@vue/test-utils": "2.4.6",
    "eslint": "8.54.0",
    "jsdom": "28.1.0",
    "prettier": "2.7.1",
    "tsdown": "0.20.3",
    "typescript": "^5.2.2",
    "vite": "7.3.1",
    "vitest": "4.0.18",
    "vue": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "vue-demi"
    ]
  }
}
