{
  "name": "@muxiu1997/vue-easy-di",
  "type": "module",
  "version": "0.1.0-rc.2",
  "packageManager": "pnpm@10.30.3",
  "description": "Type-safe dependency injection for Vue, simplified into a single composable.",
  "source": "src/index.ts",
  "author": "MuXiu1997 <muxiu1997@muxiu1997.com> (https://github.com/MuXiu1997)",
  "license": "MIT",
  "homepage": "https://github.com/MuXiu1997/vue-easy-di#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MuXiu1997/vue-easy-di.git"
  },
  "bugs": "https://github.com/MuXiu1997/vue-easy-di/issues",
  "keywords": [
    "vue",
    "DI",
    "dependency injection",
    "provider",
    "inject"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "script": "./dist/index.iife.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "unpkg": "dist/index.iife.js",
  "jsdelivr": "dist/index.iife.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "eslint --fix .",
    "test": "vitest --typecheck",
    "coverage": "vitest --typecheck --coverage",
    "build": "tsdown"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "7.6.1",
    "@types/node": ">=24",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "@vue/server-renderer": "3.5.27",
    "@vue/test-utils": "2.4.6",
    "eslint": "10.0.2",
    "eslint-plugin-format": "2.0.1",
    "jsdom": "28.1.0",
    "tsdown": "0.20.3",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.0.18",
    "vue": "^3.5.0"
  }
}
